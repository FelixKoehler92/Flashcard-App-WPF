<Window x:Class="FlashcardGUI.LearnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Learning Session" Height="600" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Moderner grauer Button (Show Answer) -->
        <Style TargetType="Button" x:Key="ModernMenuButton">
            <Setter Property="Background" Value="#55555A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D6D72"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Moderner roter Button (Hard) -->
        <Style TargetType="Button" x:Key="ModernDangerButton">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EF5350"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#C62828"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Moderner oranger Button (Medium) -->
        <Style TargetType="Button" x:Key="ModernWarningButton">
            <Setter Property="Background" Value="#F57C00"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF9800"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E65100"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Moderner grüner Button (Easy) -->
        <Style TargetType="Button" x:Key="ModernSuccessButton">
            <Setter Property="Background" Value="#388E3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4CAF50"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2E7D32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" x:Name="TxtProgress" Text="Card 1 of 5" Foreground="#A0A0A0" FontSize="16" HorizontalAlignment="Left"/>
            <TextBlock Grid.Column="1" x:Name="TxtCategoryLevel" Text="[C#] - Level 1" Foreground="#A0A0A0" FontSize="16" HorizontalAlignment="Right"/>
        </Grid>

        <Border Grid.Row="1" Background="#2D2D30" CornerRadius="15" Margin="0,0,0,20" Padding="20">

            <!-- Der ScrollViewer schützt vor abgeschnittenem Text -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="Question:" Foreground="#707070" FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtQuestion" Text="What is OOP?" Foreground="White" FontSize="24" FontWeight="SemiBold" 
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,20"/>

                    <TextBox x:Name="TxtUserInput" Background="#1E1E1E" Foreground="White" BorderBrush="#55555A" 
                             BorderThickness="1" Padding="10,8" Margin="0,0,0,20" FontSize="16" 
                             TextWrapping="Wrap" AcceptsReturn="True"/>

                    <StackPanel x:Name="AnswerPanel" Visibility="Hidden">
                        <TextBlock x:Name="TxtFeedback" Text="Perfect Match!" Foreground="#4CAF50" FontSize="18" 
                                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <TextBlock Text="Correct Answer:" Foreground="#707070" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtAnswer" Text="Object Oriented Programming" Foreground="#4CAF50" FontSize="22" 
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

        </Border>

        <Grid Grid.Row="2" Height="50">

            <Button x:Name="BtnShowAnswer" Content="Show Answer" Click="BtnShowAnswer_Click"
                    Style="{StaticResource ModernMenuButton}" FontSize="18" FontWeight="Bold" 
                    Visibility="Visible"/>

            <StackPanel x:Name="RatingButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="Hidden">
                <Button Content="Hard (1)" Click="BtnRate_Click" Tag="1" Width="120" Margin="10,0"
                        Style="{StaticResource ModernDangerButton}" FontSize="16" FontWeight="Bold"/>

                <Button Content="Medium (2)" Click="BtnRate_Click" Tag="2" Width="120" Margin="10,0"
                        Style="{StaticResource ModernWarningButton}" FontSize="16" FontWeight="Bold"/>

                <Button Content="Easy (3)" Click="BtnRate_Click" Tag="3" Width="120" Margin="10,0"
                        Style="{StaticResource ModernSuccessButton}" FontSize="16" FontWeight="Bold"/>
            </StackPanel>

        </Grid>
    </Grid>
</Window>