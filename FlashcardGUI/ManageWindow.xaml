<Window x:Class="FlashcardGUI.ManageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Cards" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Moderner roter Button (Delete) -->
        <Style TargetType="Button" x:Key="ModernDangerButton">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EF5350"/>
                                <!-- Helleres Rot beim Hovern -->
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#C62828"/>
                                <!-- Dunkles Rot beim Klicken -->
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="MANAGE FLASHCARDS" Foreground="#E0E0E0" FontSize="20" FontWeight="Bold" 
                   Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <!-- Das DataGrid -->
        <DataGrid x:Name="GridCards" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" 
                  Background="#2D2D30" Foreground="White" RowBackground="#3E3E42" AlternatingRowBackground="#2D2D30"
                  BorderBrush="#55555A" BorderThickness="1" SelectionMode="Single" 
                  IsReadOnly="True" Margin="0,0,0,20">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1E1E1E"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10,5,10,5"/>
                    <Setter Property="BorderBrush" Value="#55555A"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                <DataGridTextColumn Header="Question" Binding="{Binding Question}" Width="*"/>
                <DataGridTextColumn Header="Answer" Binding="{Binding Answer}" Width="*"/>
                <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <!-- Delete Button mit neuem Style -->
            <Button Content="Delete Selected Card" Click="BtnDelete_Click" 
                    Style="{StaticResource ModernDangerButton}" FontSize="14" FontWeight="Bold"
                    Padding="15,10"/>
        </StackPanel>
    </Grid>
</Window>