<Window x:Class="FlashcardGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flashcard Learn APP" 
        Height="1080" Width="1920" 
        WindowState="Maximized" 
        WindowStartupLocation="CenterScreen"
        Background="#181818">

    <Window.Resources>
        <!-- Style für den unsichtbaren About-Button (wird beim Hovern sichtbar) -->
        <Style TargetType="Button" x:Key="ModernAboutButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2D30"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style für die normalen Menü-Buttons (Dunkelgrau) -->
        <Style TargetType="Button" x:Key="ModernMenuButton">
            <Setter Property="Background" Value="#333337"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#55555A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style für den primären Button (Blau) -->
        <Style TargetType="Button" x:Key="ModernPrimaryButton">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1C97EA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="50">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ABOUT BUTTON -->
        <Button Grid.Row="0" Click="BtnAbout_Click" Style="{StaticResource ModernAboutButton}" 
                HorizontalAlignment="Right" VerticalAlignment="Top" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="About" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <!-- HEADER MIT UNTERTITEL -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,50">
            <TextBlock Text="FLASHCARD Learn APP" Foreground="#FFFFFF" FontSize="42" FontWeight="Black" 
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Ready for your next learning session?" Foreground="#8A8A8A" FontSize="18" 
                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- STATISTIK-BEREICH -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Total Cards -->
            <Border Background="#252526" CornerRadius="15" Margin="25" Width="320" Height="240">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="8" Opacity="0.4" Color="Black"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE81E;" Foreground="#007ACC" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="TOTAL CARDS" Foreground="#A0A0A0" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TotalCardsText" Text="0" Foreground="#FFFFFF" FontSize="80" FontWeight="Light" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Due for Review -->
            <Border Background="#252526" CornerRadius="15" Margin="25" Width="320" Height="240">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="8" Opacity="0.4" Color="Black"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE916;" Foreground="#E51400" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="DUE FOR REVIEW" Foreground="#A0A0A0" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="DueCardsText" Text="0" Foreground="#FFFFFF" FontSize="80" FontWeight="Light" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- BUTTON-BEREICH -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,50,0,30">

            <Button Click="BtnAddCard_Click" Style="{StaticResource ModernMenuButton}" Padding="25,15" Margin="15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Add New Card" FontSize="20" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Click="BtnStartLearning_Click" Style="{StaticResource ModernPrimaryButton}" Padding="35,15" Margin="15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Start Learning" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Click="BtnManageCards_Click" Style="{StaticResource ModernMenuButton}" Padding="25,15" Margin="15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Manage Cards" FontSize="20" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </StackPanel>
    </Grid>
</Window>