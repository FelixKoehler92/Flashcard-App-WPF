<Window x:Class="FlashcardGUI.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Flashcard Learning App" Height="350" Width="450"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Moderner Button Style für den Close Button -->
        <Style TargetType="Button" x:Key="ModernCloseButton">
            <Setter Property="Background" Value="#333337"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#55555A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">

        <!-- App Titel & Version -->
        <TextBlock Text="🧠 Flashcard Learning App" Foreground="#E0E0E0" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
        <TextBlock Text="Version 1.0.0" Foreground="#A0A0A0" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,25"/>

        <!-- Entwickler Info -->
        <TextBlock Text="Developed by:" Foreground="#707070" FontSize="14" HorizontalAlignment="Center"/>
        <TextBlock Text="Felix Köhler" Foreground="#007ACC" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Kurzbeschreibung -->
        <TextBlock Text="A modern Spaced Repetition App&#x0a;built with C#, WPF, and SQLite." 
                   Foreground="#A0A0A0" FontSize="14" TextAlignment="Center" Margin="0,0,0,30" LineHeight="20"/>

        <!-- Schließen Button -->
        <Button Content="Close" Click="BtnClose_Click" Width="120" Height="40"
                Style="{StaticResource ModernCloseButton}"/>

    </StackPanel>
</Window>