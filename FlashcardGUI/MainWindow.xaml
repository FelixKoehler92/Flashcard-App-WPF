<Window x:Class="FlashcardGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flashcard Learn APP" 
        Height="1080" Width="1920" 
        WindowState="Maximized" 
        WindowStartupLocation="CenterScreen"
        Background="#181818">

    <Grid Margin="50">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER MIT UNTERTITEL -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,50">
            <TextBlock Text="FLASHCARD Learn APP" Foreground="#FFFFFF" FontSize="42" FontWeight="Black" 
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Ready for your next learning session?" Foreground="#8A8A8A" FontSize="18" 
                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- STATISTIK-BEREICH -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- Total Cards -->
            <Border Background="#252526" CornerRadius="15" Margin="25" Width="320" Height="240">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="8" Opacity="0.4" Color="Black"/>
                </Border.Effect>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE81E;" Foreground="#007ACC" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="TOTAL CARDS" Foreground="#A0A0A0" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TotalCardsText" Text="0" Foreground="#FFFFFF" FontSize="80" FontWeight="Light" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Due for Review -->
            <Border Background="#252526" CornerRadius="15" Margin="25" Width="320" Height="240">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="8" Opacity="0.4" Color="Black"/>
                </Border.Effect>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE916;" Foreground="#E51400" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="DUE FOR REVIEW" Foreground="#A0A0A0" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="DueCardsText" Text="0" Foreground="#FFFFFF" FontSize="80" FontWeight="Light" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- BUTTON-BEREICH -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,50,0,30">

            <Button Click="BtnAddCard_Click" Background="#333337" Foreground="White" Padding="25,15" Margin="15" BorderThickness="0" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Add New Card" FontSize="20" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Click="BtnStartLearning_Click" Background="#007ACC" Foreground="White" Padding="35,15" Margin="15" BorderThickness="0" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Start Learning" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Click="BtnManageCards_Click" Background="#333337" Foreground="White" Padding="25,15" Margin="15" BorderThickness="0" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Manage Cards" FontSize="20" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </StackPanel>
    </Grid>
</Window>