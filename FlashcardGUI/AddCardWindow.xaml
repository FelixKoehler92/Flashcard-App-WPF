<Window x:Class="FlashcardGUI.AddCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Flashcard" Height="550" Width="400"
        WindowStartupLocation="CenterOwner" 
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Style für Dropdown (bereits vorhanden) -->
        <Style TargetType="ComboBox" x:Key="DarkCombo">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2D2D30" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Grid.Column="2" Focusable="false" 
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#2D2D30" CornerRadius="0">
                                            <Path x:Name="Arrow" Fill="#A0A0A0" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False" Margin="8,5,25,5" VerticalAlignment="Center" HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#2D2D30" BorderThickness="1" BorderBrush="#55555A"/>
                                    <ScrollViewer Margin="0" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Moderner blauer Button (+) -->
        <Style TargetType="Button" x:Key="ModernPrimaryButton">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1C97EA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Moderner grüner Button (Save Cat.) -->
        <Style TargetType="Button" x:Key="ModernSuccessButton">
            <Setter Property="Background" Value="#388E3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4CAF50"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2E7D32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Moderner transparenter Button (Cancel) -->
        <Style TargetType="Button" x:Key="ModernGhostButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2D30"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Moderner grauer Button (Save Card) -->
        <Style TargetType="Button" x:Key="ModernMenuButton">
            <Setter Property="Background" Value="#55555A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D6D72"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Der ScrollViewer schützt vor zu langen Texten -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="25">

            <TextBlock Text="NEW FLASHCARD" Foreground="#E0E0E0" FontSize="20" FontWeight="Bold" 
                       Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Text="Category:" Foreground="#A0A0A0" Margin="0,0,0,5"/>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="CmbCategory" Grid.Column="0" 
                          Style="{StaticResource DarkCombo}" FontSize="14" 
                          DisplayMemberPath="Name" SelectedValuePath="Name"/>

                <Button Content="+" Grid.Column="1" Click="BtnToggleNewCategory_Click" Width="35" Margin="10,0,0,0" 
                        Style="{StaticResource ModernPrimaryButton}" FontSize="16" FontWeight="Bold"/>
            </Grid>

            <StackPanel x:Name="PanelNewCategory" Visibility="Collapsed" Margin="0,0,0,15" Orientation="Horizontal">
                <TextBox x:Name="TxtNewCategory" Width="220" Background="#2D2D30" Foreground="White" BorderBrush="#007ACC" BorderThickness="1" Padding="5"/>
                <Button Content="Save Cat." Click="BtnSaveCategory_Click" Width="75" Margin="10,0,0,0" 
                        Style="{StaticResource ModernSuccessButton}"/>
            </StackPanel>

            <TextBlock Text="Question:" Foreground="#A0A0A0" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtQuestion" Background="#2D2D30" Foreground="White" 
                     BorderThickness="0" Padding="10,8" Margin="0,0,0,15" TextWrapping="Wrap" AcceptsReturn="True" FontSize="14"/>

            <TextBlock Text="Answer:" Foreground="#A0A0A0" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtAnswer" Background="#2D2D30" Foreground="White" 
                     BorderThickness="0" Padding="10,8" Margin="0,0,0,25" TextWrapping="Wrap" AcceptsReturn="True" FontSize="14"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Cancel Button -->
                <Button Content="Cancel" Click="BtnCancel_Click" Padding="15,8" Margin="0,0,10,0" 
                        Style="{StaticResource ModernGhostButton}"/>

                <!-- Save Card Button -->
                <Button Content="Save Card" Click="BtnSave_Click" Padding="20,8" FontWeight="Bold" 
                        Style="{StaticResource ModernMenuButton}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>